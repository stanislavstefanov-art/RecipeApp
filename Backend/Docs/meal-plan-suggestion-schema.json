{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MealPlanSuggestionDto",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "entries", "confidence", "needsReview", "notes"],
  "properties": {
    "name": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["baseRecipeId", "plannedDate", "mealType", "scope", "assignments"],
        "properties": {
          "baseRecipeId": { "type": "string", "format": "uuid" },
          "plannedDate": { "type": "string", "format": "date" },
          "mealType": { "type": "integer" },
          "scope": { "type": "integer" },
          "assignments": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["personId", "assignedRecipeId", "recipeVariationId", "portionMultiplier", "notes"],
              "properties": {
                "personId": { "type": "string", "format": "uuid" },
                "assignedRecipeId": { "type": "string", "format": "uuid" },
                "recipeVariationId": { "type": ["string", "null"], "format": "uuid" },
                "portionMultiplier": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "notes": { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "needsReview": { "type": "boolean" },
    "notes": { "type": ["string", "null"] }
  }
}